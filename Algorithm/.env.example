# FTIP System - Local defaults
# Copy to .env and adjust as needed.

# Database (Postgres)
FTIP_DB_ENABLED=1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
FTIP_MIGRATIONS_AUTO=1

# Assistant / narration
FTIP_LLM_ENABLED=1
OPENAI_API_KEY=

# Multi-source data fabric
FTIP_DATA_FABRIC_ENABLED=1
FTIP_DATA_FABRIC_TIMEOUT_SECONDS=8
FTIP_DATA_FABRIC_NEWS_DAYS=14
FTIP_DATA_FABRIC_NEWS_LIMIT=24

# Key-backed market / intelligence providers
MASSIVE_API_KEY=
FINNHUB_API_KEY=
FRED_API_KEY=
SECEDGAR_API_KEY=
ALPHAVANTAGE_API_KEY=
GNEWS_API_KEY=
NEWS_API_KEY=
SEC_USER_AGENT="FTIP System/1.0 (ops@example.com)"

# No-key sources (enabled by default unless explicitly turned off)
GDELT_ENABLED=1
WORLD_BANK_ENABLED=1
STOOQ_ENABLED=1

# Homebrew Postgres alternative (no password by default):
# DATABASE_URL=postgresql://$USER@localhost:5432/postgres
